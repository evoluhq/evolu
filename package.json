{
  "private": true,
  "name": "@evolu/monorepo",
  "scripts": {
    "dev": "turbo run dev --filter=relay --filter=web",
    "relay": "turbo --filter relay dev",
    "build": "pnpm clean:ts && turbo --filter \"@evolu/*\" --filter relay build",
    "build:web": "pnpm build && pnpm build:docs && turbo --filter web build",
    "build:web:fast": "rm -rf 'apps/web/src/app/(docs)/docs/api-reference' && turbo --filter web build",
    "build:docs": "typedoc && pnpm --dir apps/web fix:docs",
    "build:expo": "turbo --filter @example/react-expo build",
    "typecheck": "tsc --build tsconfig.typecheck.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ios": "NODE_ENV=development vitest run --config vitest.ios.config.mts",
    "test:ios:bootstrap": "vitest-mobile bootstrap --platform ios",
    "playwright:install": "pnpm --filter @evolu/common exec playwright install chromium firefox webkit",
    "test:watch": "vitest",
    "start": "turbo start",
    "lint": "eslint",
    "biome": "biome check",
    "lint-monorepo": "pnpm dlx sherif@latest --ignore-dependency react@19.2.0",
    "verify": "pnpm typecheck && pnpm build && pnpm test:coverage && pnpm biome && pnpm lint-monorepo && pnpm build:docs && pnpm lint",
    "clean:ts": "tsc --build --clean tsconfig.typecheck.json",
    "clean:dry": "git clean -Xnd",
    "// clean": "Retry because macOS can report large hoisted node_modules trees as non-empty while cleaning.",
    "clean": "git clean -Xdf || git clean -Xdf || git clean -Xdf || git clean -Xdf",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,md,mdx}\"",
    "version": "changeset version",
    "release": "pnpm build && pnpm changeset publish",
    "ios": "pnpm --dir examples/react-expo ios",
    "android": "pnpm --dir examples/react-expo android",
    "examples:toggle-deps": "node ./scripts/toggle-examples-deps.mts",
    "examples:build": "turbo --filter \"@example/*\" build",
    "examples:react-nextjs:dev": "turbo --filter @example/react-nextjs dev",
    "examples:react-vite-pwa:dev": "turbo --filter @example/react-vite-pwa dev",
    "examples:svelte-vite-pwa:dev": "turbo --filter @example/svelte-vite-pwa dev",
    "examples:vue-vite-pwa:dev": "turbo --filter @example/vue-vite-pwa dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^24.10.9",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-plugin-jsdoc": "^63.0.6",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-embed": "^0.5.1",
    "prettier-plugin-jsdoc": "^1.8.0",
    "prettier-plugin-sql-cst": "^0.22.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.1",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2",
    "vitest-mobile": "^0.4.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
