{
  "private": true,
  "name": "@evolu/monorepo",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@evolu/relay --filter=web",
    "relay": "turbo --filter @evolu/relay dev",
    "build": "turbo --filter @evolu/* build",
    "build:web": "bun run build:docs && turbo --filter web build",
    "build:docs": "typedoc && cd apps/web && bun run fix:docs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "start": "turbo start",
    "lint": "eslint --cache",
    "biome": "biome check",
    "lint-monorepo": "bunx sherif@latest",
    "verify": "bun run build && bun run test:coverage && bun run lint && bun run biome && bun run lint-monorepo && bun run build:docs",
    "clean": "turbo clean && rimraf node_modules .turbo .eslintcache out bun.lock coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,md,mdx}\"",
    "version": "changeset version",
    "release": "bun run build && bunx changeset publish",
    "ios": "cd examples/react-expo && bun run ios",
    "android": "cd examples/react-expo && bun run android",
    "examples:toggle-deps": "node --experimental-strip-types ./scripts/toggle-examples-deps.mts",
    "examples:build": "turbo --filter @example/* build",
    "examples:react-nextjs:dev": "turbo --filter @example/react-nextjs dev",
    "examples:react-vite-pwa:dev": "turbo --filter @example/react-vite-pwa dev",
    "examples:svelte-vite-pwa:dev": "turbo --filter @example/svelte-vite-pwa dev",
    "examples:vue-vite-pwa:dev": "turbo --filter @example/vue-vite-pwa dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.2",
    "@types/inquirer": "^9.0.9",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/browser": "^4.0.17",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.39.2",
    "eslint-plugin-jsdoc": "^62.4.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.0",
    "prettier-plugin-embed": "^0.5.1",
    "prettier-plugin-jsdoc": "^1.8.0",
    "prettier-plugin-sql-cst": "^0.18.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.2",
    "turbo": "^2.8.1",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "patchedDependencies": {
    "@changesets/assemble-release-plan@6.0.9": "patches/@changesets__assemble-release-plan.patch"
  },
  "packageManager": "bun@1.3.9"
}
