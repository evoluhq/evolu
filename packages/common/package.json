{
  "name": "@evolu/common",
  "version": "8.0.0-next.6",
  "description": "TypeScript library and local-first platform",
  "keywords": [
    "evolu",
    "local-first",
    "sqlite",
    "crdt",
    "e2ee"
  ],
  "author": "Daniel Steigerwald <daniel@steigerwald.cz>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evoluhq/evolu.git"
  },
  "bugs": {
    "url": "https://github.com/evoluhq/evolu/issues"
  },
  "homepage": "https://evolu.dev",
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./src/index.ts"
    },
    "./local-first": {
      "types": "./dist/src/local-first/index.d.ts",
      "default": "./src/local-first/index.ts"
    },
    "./polyfills": {
      "types": "./dist/src/Polyfills.d.ts",
      "default": "./src/Polyfills.ts"
    }
  },
  "typesVersions": {
    "*": {
      "polyfills": [
        "./dist/src/Polyfills.d.ts"
      ],
      "local-first": [
        "./dist/src/local-first/index.d.ts"
      ]
    }
  },
  "files": [
    "dist/src/**",
    "src/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "prepack": "npm run build",
    "format": "prettier --write \"src/*.{ts,tsx,md}\""
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "@noble/hashes": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "kysely": "^0.29.4",
    "msgpackr": "^2.0.4",
    "random": "^5.4.1"
  },
  "devDependencies": {
    "@evolu/typescript-config": "workspace:*",
    "@types/node": "^24.10.9",
    "@typescript/native": "npm:typescript@^7.0.2",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  },
  "publishConfig": {
    "access": "public",
    "types": "./dist/src/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "import": "./dist/src/index.js",
        "browser": "./dist/src/index.js",
        "react-native": "./dist/src/index.js",
        "default": "./dist/src/index.js"
      },
      "./local-first": {
        "types": "./dist/src/local-first/index.d.ts",
        "import": "./dist/src/local-first/index.js",
        "default": "./dist/src/local-first/index.js"
      },
      "./polyfills": {
        "types": "./dist/src/Polyfills.d.ts",
        "import": "./dist/src/Polyfills.js",
        "browser": "./dist/src/Polyfills.js",
        "react-native": "./dist/src/Polyfills.js",
        "default": "./dist/src/Polyfills.js"
      }
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "sideEffects": false
}
