{
  "name": "@evolu/react-native",
  "version": "15.0.0-next.0",
  "description": "Evolu for React Native and Expo",
  "keywords": [
    "evolu",
    "expo",
    "expo-sqlite",
    "op-sqlite",
    "react-native",
    "react-hooks"
  ],
  "author": "Daniel Steigerwald <daniel@steigerwald.cz>",
  "license": "MIT",
  "repository": "evoluhq/evolu",
  "bugs": {
    "url": "https://github.com/evoluhq/evolu/issues"
  },
  "homepage": "https://evolu.dev",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "react-native": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./polyfills": {
      "types": "./dist/src/Polyfills.d.ts",
      "react-native": "./dist/src/Polyfills.js",
      "default": "./dist/src/Polyfills.js"
    },
    "./expo-sqlite": {
      "types": "./dist/src/exports/expo-sqlite.d.ts",
      "react-native": "./dist/src/exports/expo-sqlite.js",
      "browser": "./dist/src/web.js",
      "default": "./dist/src/exports/expo-sqlite.js"
    },
    "./expo-op-sqlite": {
      "types": "./dist/src/exports/expo-op-sqlite.d.ts",
      "react-native": "./dist/src/exports/expo-op-sqlite.js",
      "browser": "./dist/src/web.js",
      "default": "./dist/src/exports/expo-op-sqlite.js"
    },
    "./bare-op-sqlite": {
      "types": "./dist/src/exports/bare-op-sqlite.d.ts",
      "react-native": "./dist/src/exports/bare-op-sqlite.js",
      "browser": "./dist/src/web.js",
      "default": "./dist/src/exports/bare-op-sqlite.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/src/index.d.ts"
      ],
      "polyfills": [
        "./dist/src/Polyfills.d.ts"
      ],
      "expo-sqlite": [
        "./dist/src/exports/expo-sqlite.d.ts"
      ],
      "expo-op-sqlite": [
        "./dist/src/exports/expo-op-sqlite.d.ts"
      ],
      "bare-op-sqlite": [
        "./dist/src/exports/bare-op-sqlite.d.ts"
      ]
    }
  },
  "files": [
    "dist/src/**",
    "src/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "prepack": "npm run build",
    "format": "prettier --write \"src/*.{ts,tsx,md}\""
  },
  "dependencies": {
    "array-from-async": "^3.0.0",
    "array.prototype.tosorted": "^1.1.4",
    "promise.try": "^2.0.1",
    "promise.withresolvers": "^1.0.4",
    "set.prototype.difference": "^1.1.7",
    "set.prototype.intersection": "^1.1.8",
    "set.prototype.isdisjointfrom": "^1.1.5",
    "set.prototype.issubsetof": "^1.1.4",
    "set.prototype.issupersetof": "^1.1.3",
    "set.prototype.symmetricdifference": "^1.1.3",
    "set.prototype.union": "^1.1.3"
  },
  "devDependencies": {
    "@evolu/common": "workspace:*",
    "@evolu/react": "workspace:*",
    "@evolu/typescript-config": "workspace:*",
    "@op-engineering/op-sqlite": "^15.2.2",
    "@types/react": "catalog:react19",
    "expo": "^55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-sqlite": "~55.0.10",
    "react": "catalog:react19",
    "react-native": "0.83.2",
    "react-native-nitro-modules": "0.34.1",
    "react-native-sensitive-info": "6.0.0-rc.11",
    "react-native-svg": "15.15.3",
    "typescript": "^6"
  },
  "peerDependencies": {
    "@evolu/common": "^8.0.0-next.0",
    "@evolu/react": "^11.0.0-next.0",
    "@op-engineering/op-sqlite": ">=12",
    "expo": ">=55",
    "expo-secure-store": ">=55",
    "expo-sqlite": ">=55",
    "react": ">=19",
    "react-native": ">=0.83",
    "react-native-nitro-modules": ">=0.34",
    "react-native-sensitive-info": ">=6",
    "react-native-svg": ">=15.15"
  },
  "peerDependenciesMeta": {
    "@op-engineering/op-sqlite": {
      "optional": true
    },
    "expo": {
      "optional": true
    },
    "expo-sqlite": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    },
    "react-native-nitro-modules": {
      "optional": true
    },
    "react-native-sensitive-info": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "sideEffects": false
}
