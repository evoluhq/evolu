{
  "extends": "@evolu/tsconfig/universal-esm.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "allowJs": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "tsBuildInfoFile": "dist/.tsBuildInfo"
  },
  "include": ["src", "test", "vitest.config.ts"],
  "exclude": ["dist", "node_modules"],
  "references": [{ "path": "../common" }, { "path": "../react" }]
}
