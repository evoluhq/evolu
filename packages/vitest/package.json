{
  "name": "@evolu/vitest",
  "version": "1.0.0-next.0",
  "description": "Vitest assertions for Evolu",
  "keywords": [
    "evolu",
    "vitest"
  ],
  "author": "Daniel Steigerwald <daniel@steigerwald.cz>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evoluhq/evolu.git"
  },
  "bugs": {
    "url": "https://github.com/evoluhq/evolu/issues"
  },
  "homepage": "https://evolu.dev",
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist/src/**",
    "src/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "prepack": "npm run build",
    "format": "prettier --write \"src/*.{ts,md}\""
  },
  "devDependencies": {
    "@evolu/common": "workspace:*",
    "@evolu/typescript-config": "workspace:*",
    "@typescript/native": "npm:typescript@^7.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@evolu/common": "^8.0.0-next.0",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public",
    "types": "./dist/src/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "import": "./dist/src/index.js"
      }
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "sideEffects": false
}
