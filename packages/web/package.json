{
  "name": "@evolu/web",
  "version": "3.0.0-next.0",
  "description": "Evolu for web",
  "keywords": [
    "evolu",
    "web"
  ],
  "author": "Daniel Steigerwald <daniel@steigerwald.cz>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evoluhq/evolu.git"
  },
  "bugs": {
    "url": "https://github.com/evoluhq/evolu/issues"
  },
  "homepage": "https://evolu.dev",
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "browser": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src/**",
    "src/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "prepack": "npm run build",
    "format": "prettier --write \"src/*.{ts,tsx,md}\""
  },
  "dependencies": {
    "@evolu/sqlite-wasm": "2.2.4",
    "idb-keyval": "^6.2.2"
  },
  "devDependencies": {
    "@evolu/common": "workspace:*",
    "@evolu/typescript-config": "workspace:*",
    "@types/node": "^24.10.9",
    "@types/sharedworker": "^0.0.221",
    "@types/web-locks-api": "^0.0.5",
    "typescript": "^6",
    "user-agent-data-types": "^0.4.2"
  },
  "peerDependencies": {
    "@evolu/common": "^8.0.0-next.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "sideEffects": false
}
