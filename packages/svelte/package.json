{
  "name": "@evolu/svelte",
  "version": "3.0.0-next.0",
  "description": "Evolu for Svelte",
  "keywords": [
    "evolu",
    "svelte"
  ],
  "homepage": "https://evolu.dev",
  "bugs": {
    "url": "https://github.com/evoluhq/evolu/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evoluhq/evolu.git"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.svelte.d.ts",
      "svelte": "./src/lib/index.svelte.ts",
      "default": "./src/lib/index.svelte.ts"
    }
  },
  "types": "./dist/index.svelte.d.ts",
  "files": [
    "dist",
    "src/**",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json && pnpm package",
    "prepack": "pnpm build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "package": "svelte-package",
    "prepublishOnly": "pnpm package",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@evolu/common": "workspace:*",
    "@evolu/typescript-config": "workspace:*",
    "@evolu/web": "workspace:*",
    "@sveltejs/package": "^2.5.7",
    "@tsconfig/svelte": "^5.0.6",
    "@typescript/native": "npm:typescript@^7.0.2",
    "svelte": "^5.56.7",
    "svelte-check": "^4.3.6",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  },
  "peerDependencies": {
    "@evolu/common": "^8.0.0-next.0",
    "@evolu/web": "^3.0.0-next.0",
    "svelte": ">=5"
  },
  "publishConfig": {
    "access": "public",
    "types": "./dist/index.svelte.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.svelte.d.ts",
        "svelte": "./dist/index.svelte.js"
      }
    }
  }
}
