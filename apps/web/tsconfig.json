{
  "extends": "@evolu/typescript-config/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "css.d.ts",
    "types.d.ts",
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    "src/**/*.mjs",
    ".next/types/**/*.ts",
    "tailwind.config.js"
  ],
  "exclude": ["node_modules"],
  "references": [
    { "path": "../../packages/common" },
    { "path": "../../packages/react" },
    { "path": "../../packages/react-web" },
    { "path": "../../packages/web" }
  ]
}
